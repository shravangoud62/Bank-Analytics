            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Black' fontsize='12'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bank_analytics (banking_data)' name='federated.0j3qvr61hymfbm1bfuzwi1hxq9i9' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='LOAN METRIC' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;No of Loans&quot;'>
              <calculation class='tableau' formula='&quot;No of Loans&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0j3qvr61hymfbm1bfuzwi1hxq9i9'>
            <column datatype='string' name='[Account_ID]' role='dimension' type='nominal' />
            <column datatype='string' name='[Age]' role='dimension' type='nominal' />
            <column caption='Loan Metric' datatype='real' name='[Calculation_753508539102568458]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;No of Loans&quot; THEN COUNT([Account_ID])&#13;&#10;WHEN &quot;Loan Amount&quot; THEN SUM([Loan_Amount])&#13;&#10;END' />
            </column>
            <column caption='Loan Term' datatype='integer' name='[Calculation_753508539142397984]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(LEFT([Term], 2))' />
            </column>
            <column datatype='date' datatype-customized='true' name='[Disbursement_Date]' role='dimension' type='ordinal' />
            <column datatype='real' default-format='c&quot;₹ &quot;#,##0;&quot;₹ &quot;-#,##0' name='[Loan_Amount]' role='measure' type='quantitative' />
            <column datatype='string' name='[Purpose_Category]' role='dimension' type='nominal' />
            <column datatype='string' name='[State_Name]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column datatype='string' name='[Term]' role='dimension' type='nominal' />
            <column-instance column='[Disbursement_Date]' derivation='Month' name='[mn:Disbursement_Date:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Age]' derivation='None' name='[none:Age:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_753508539142397984]' derivation='None' name='[none:Calculation_753508539142397984:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Purpose_Category]' derivation='None' name='[none:Purpose_Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[State_Name]' derivation='None' name='[none:State_Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_753508539102568458]' derivation='User' name='[usr:Calculation_753508539102568458:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Disbursement_Date]' derivation='Year' name='[yr:Disbursement_Date:ok]' pivot='key' type='ordinal' />
