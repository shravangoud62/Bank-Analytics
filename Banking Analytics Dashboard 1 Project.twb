      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0j3qvr61hymfbm1bfuzwi1hxq9i9].[cnt:Account ID:qk]&quot;' value='Total Loans' />
          <alias key='&quot;[federated.0j3qvr61hymfbm1bfuzwi1hxq9i9].[cnt:Account_ID:qk]&quot;' value='No of Loans' />
          <alias key='&quot;[federated.0j3qvr61hymfbm1bfuzwi1hxq9i9].[sum:Total Rrec int:qk]&quot;' value='Total Interest' />
          <alias key='&quot;[federated.0j3qvr61hymfbm1bfuzwi1hxq9i9].[sum:Total_Rec_Int:qk]&quot;' value='Interest Received' />
        </aliases>
      </column>
      <column datatype='string' name='[Account_ID]' role='dimension' type='nominal' />
      <column datatype='string' name='[Age]' role='dimension' type='nominal' />
      <column datatype='string' name='[Branch_Name]' role='dimension' type='nominal' />
      <column caption='Total Collection' datatype='real' name='[Calculation_753508539064274945]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total_Rec_Prncp]) + SUM([Total_Rec_Int])' />
      </column>
      <column caption='Selected Revenue Metric' datatype='real' name='[Calculation_753508539075739653]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &quot;Interest&quot; THEN SUM([Total_Rec_Int])&#13;&#10;  WHEN &quot;Fees&quot; THEN SUM([Total_Fees]) &#13;&#10;    + SUM([Collection_Recovery_fee])&#13;&#10;    + SUM([Total_Rec_Late_fee])&#13;&#10;    + SUM([Recoveries])&#13;&#10;  WHEN &quot;Total Revenue&quot; THEN &#13;&#10;    SUM([Total_Rec_Int]) &#13;&#10;    + SUM([Total_Fees]) &#13;&#10;    + SUM([Total_Rec_Late_fee]) &#13;&#10;    + SUM([Recoveries]) &#13;&#10;    + SUM([Collection_Recovery_fee])&#13;&#10;END' />
      </column>
      <column caption='Loan Metric' datatype='real' name='[Calculation_753508539102568458]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;No of Loans&quot; THEN COUNT([Account_ID])&#13;&#10;WHEN &quot;Loan Amount&quot; THEN SUM([Loan_Amount])&#13;&#10;END' />
      </column>
      <column caption='Def Loan Flag' datatype='integer' name='[Calculation_753508539117162516]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Is_Default_Loan] = &quot;Y&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Client Metic' datatype='integer' name='[Calculation_753508539121590293]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 3]&#13;&#10;WHEN &quot;Defaulter Clients&quot; THEN SUM(IF [Is_Default_Loan] = &quot;Y&quot; THEN 1 ELSE 0 END)&#13;&#10;WHEN &quot;Delinquent Clients&quot; THEN SUM(IF [Is_Delinquent_Loan] = &quot;Y&quot; THEN 1 ELSE 0 END)&#13;&#10;END' />
      </column>
      <column caption='Delinquent Loan Rate' datatype='real' default-format='p0.00%' name='[Calculation_753508539134767127]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Is_Delinquent_Loan] = &quot;Y&quot; THEN 1 ELSE 0 END) /COUNT([Account_ID])' />
      </column>
      <column caption='Default Loan Rate %' datatype='real' default-format='p0.00%' name='[Calculation_753508539135500312]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Is_Default_Loan] = &quot;Y&quot; THEN 1 ELSE 0 END) / COUNT([Account_ID])' />
      </column>
      <column caption='Non Verified Loans' datatype='integer' name='[Calculation_753508539140284446]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Verification_Status] = &quot;Not Verified&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Loan Term' datatype='integer' name='[Calculation_753508539142397984]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(LEFT([Term], 2))' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='date' datatype-customized='true' name='[Disbursement_Date]' role='dimension' type='ordinal' />
