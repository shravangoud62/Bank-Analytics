    <worksheet name='Branch Wise'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Black' fontsize='12'>&lt;</run>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Black' fontsize='12'>[Parameters].[Parameter 1]</run>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Black' fontsize='12'>&gt; by Branch</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bank_analytics (banking_data)' name='federated.0j3qvr61hymfbm1bfuzwi1hxq9i9' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Revenue Type' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Total Revenue&quot;'>
              <calculation class='tableau' formula='&quot;Total Revenue&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0j3qvr61hymfbm1bfuzwi1hxq9i9'>
            <column datatype='string' name='[Branch_Name]' role='dimension' type='nominal' />
            <column caption='Selected Revenue Metric' datatype='real' name='[Calculation_753508539075739653]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &quot;Interest&quot; THEN SUM([Total_Rec_Int])&#13;&#10;  WHEN &quot;Fees&quot; THEN SUM([Total_Fees]) &#13;&#10;    + SUM([Collection_Recovery_fee])&#13;&#10;    + SUM([Total_Rec_Late_fee])&#13;&#10;    + SUM([Recoveries])&#13;&#10;  WHEN &quot;Total Revenue&quot; THEN &#13;&#10;    SUM([Total_Rec_Int]) &#13;&#10;    + SUM([Total_Fees]) &#13;&#10;    + SUM([Total_Rec_Late_fee]) &#13;&#10;    + SUM([Recoveries]) &#13;&#10;    + SUM([Collection_Recovery_fee])&#13;&#10;END' />
            </column>
            <column datatype='real' name='[Collection_Recovery_fee]' role='measure' type='quantitative' />
            <column datatype='date' datatype-customized='true' name='[Disbursement_Date]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Purpose_Category]' role='dimension' type='nominal' />
            <column datatype='real' name='[Recoveries]' role='measure' type='quantitative' />
            <column datatype='string' name='[Religion]' role='dimension' type='nominal' />
            <column datatype='string' name='[State_Name]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column datatype='real' name='[Total_Fees]' role='measure' type='quantitative' />
            <column datatype='real' name='[Total_Rec_Int]' role='measure' type='quantitative' />
            <column datatype='real' name='[Total_Rec_Late_fee]' role='measure' type='quantitative' />
            <column datatype='string' name='[Verification_Status]' role='dimension' type='nominal' />
            <column-instance column='[Branch_Name]' derivation='None' name='[none:Branch_Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Purpose_Category]' derivation='None' name='[none:Purpose_Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[State_Name]' derivation='None' name='[none:State_Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_753508539075739653]' derivation='User' name='[usr:Calculation_753508539075739653:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Disbursement_Date]' derivation='Year' name='[yr:Disbursement_Date:ok]' pivot='key' type='ordinal' />
